{
  "$schema": "https://raw.githubusercontent.com/nicedoc/unpkg/1.0.0/tauri-apps/api/2/capabilities.schema.json",
  "identifier": "default",
  "description": "Default capabilities for Claude Proxy",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "store:default",
    "updater:default",
    "process:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible"
  ]
}
